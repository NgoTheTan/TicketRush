# Copy this file to TicketRush-backend/.env and fill in your own values.
# Create an API key in Resend, then verify a sending domain for production use.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAIL_FROM=TicketRush <onboarding@resend.dev>

# Optional; keep the default unless you use a proxy/self-hosted compatible endpoint.
RESEND_BASE_URL=https://api.resend.com
